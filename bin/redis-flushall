#!/usr/bin/env bash
# shellcheck disable=SC2016

### Flush all data from the Valkey/Redis instance via Docker Compose.
###
### Usage:
###     $ ./bin/redis-flushall
###     $ ./bin/redis-flushall --no-confirm
###
### Environment overrides:
###     COMPOSE_FILE    Compose file path  (default: compose.yaml)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
COMPOSE_FILE="${COMPOSE_FILE:-${PROJECT_DIR}/compose.yaml}"

# ── Helpers ───────────────────────────────────────────────────────
msg_info() { echo -e "$(date +'%Y-%m-%d %H:%M:%S') \e[1m[INFO]\e[0m $*"; }
msg_success() { echo -e "$(date +'%Y-%m-%d %H:%M:%S') \e[32m[OK]\e[0m $*"; }
msg_warn() { echo -e "$(date +'%Y-%m-%d %H:%M:%S') \e[33m[WARN]\e[0m $*"; }
msg_error() { echo -e "$(date +'%Y-%m-%d %H:%M:%S') \e[31m[ERROR]\e[0m $*" >&2; }

usage() {
  echo "Usage: $(basename "$0") [OPTIONS]"
  echo ""
  echo "Options:"
  echo "  --no-confirm       Skip the confirmation prompt"
  echo "  -h, --help         Show this help message"
}

docker_compose() {
  docker compose -f "$COMPOSE_FILE" "$@"
}

# ── Parse arguments ──────────────────────────────────────────────
NO_CONFIRM=false

while [[ $# -gt 0 ]]; do
  case "$1" in
  --no-confirm)
    NO_CONFIRM=true
    shift
    ;;
  -h | --help)
    usage
    exit 0
    ;;
  -*)
    msg_error "Unknown option: $1"
    usage
    exit 1
    ;;
  *)
    msg_error "Unknown argument: $1"
    usage
    exit 1
    ;;
  esac
done

# ── Pre-flight checks ───────────────────────────────────────────
if ! docker_compose ps --status running --format '{{.Name}}' 2>/dev/null |
  grep -q 'redis'; then
  msg_error "Redis (Valkey) container is not running."
  msg_error "Start it with: docker compose -f ${COMPOSE_FILE} up -d redis"
  exit 1
fi

# ── Confirmation ─────────────────────────────────────────────────
if [[ "$NO_CONFIRM" != true ]]; then
  msg_warn "This will FLUSH ALL keys from the Redis database."
  msg_warn "All cached data and Celery tasks in Redis will be lost."
  echo ""
  read -rp "Are you sure you want to continue? [y/N] " confirm
  if [[ "${confirm,,}" != "y" ]]; then
    msg_info "Operation cancelled."
    exit 0
  fi
fi

# ── Flush Redis ──────────────────────────────────────────────────
msg_info "Flushing all Redis data..."

# Using sh -c allows the REDIS_PASSWORD environment variable to be evaluated
# inside the container context where it is defined by the env_file.
if docker_compose exec -T redis sh -c 'valkey-cli -a "$REDIS_PASSWORD" FLUSHALL' >/dev/null 2>&1; then
  msg_success "Successfully flushed all Redis data."
else
  msg_error "Failed to flush Redis data."
  exit 1
fi
